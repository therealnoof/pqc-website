{
  "name": "pqc-field-guide",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "The Post-Quantum Cryptography Field Guide — a fast, modern reading site deployed on Cloudflare Workers.",
  "scripts": {
    "convert": "python3 scripts/convert.py",
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "pdf": "bash scripts/make-pdf.sh",
    "deploy": "npm run build && wrangler deploy",
    "cf:preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.2.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0"
  },
  "devDependencies": {
    "pagefind": "^1.3.0",
    "wrangler": "^4.4.0"
  }
}
