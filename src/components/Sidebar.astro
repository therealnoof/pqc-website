---
import meta from "../data/book-meta.json";

interface Props {
  current: string;
}
const { current } = Astro.props;

const order = ["Front Matter", "Chapters", "Appendices & Reference"];
const groups = order.map((name) => ({
  name,
  items: meta.chapters
    .filter((c) => c.section === name)
    .sort((a, b) => a.order - b.order),
}));
---

<aside class="sidebar" id="sidebar">
  <nav aria-label="Table of contents">
    {groups.map((g) => (
      <div class="group">
        <p class="group-title">{g.name}</p>
        <ul>
          {g.items.map((c) => (
            <li>
              <a
                href={`/read/${c.slug}/`}
                class={c.slug === current ? "current" : ""}
                aria-current={c.slug === current ? "page" : undefined}
              >
                {c.chapter && <span class="num">{c.chapter}</span>}
                <span class="label">{c.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 4rem;
    align-self: start;
    height: calc(100vh - 4rem);
    overflow-y: auto;
    padding: 1.6rem 1rem 3rem 0;
    scrollbar-width: thin;
  }
  .group + .group { margin-top: 1.4rem; }
  .group-title {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
  }
  ul { list-style: none; margin: 0; padding: 0; }
  li { margin: 0; }
  .sidebar a {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.4rem 0.7rem;
    border-radius: 8px;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.35;
    border-left: 2px solid transparent;
  }
  .sidebar a:hover { color: var(--text-strong); background: var(--surface); text-decoration: none; }
  .sidebar a.current {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 9%, transparent);
    border-left-color: var(--accent);
  }
  .num {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
    min-width: 1ch;
  }
  .sidebar a.current .num { color: var(--accent); }
</style>
