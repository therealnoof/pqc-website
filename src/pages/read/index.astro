---
import BaseLayout from "../../layouts/BaseLayout.astro";
import meta from "../../data/book-meta.json";

const order = ["Front Matter", "Chapters", "Appendices & Reference"];
const groups = order.map((name) => ({
  name,
  items: meta.chapters.filter((c) => c.section === name).sort((a, b) => a.order - b.order),
}));
---

<BaseLayout title="Contents" description="Full table of contents for The Post-Quantum Cryptography Field Guide.">
  <main id="main" class="container toc-page">
    <header class="toc-hero">
      <span class="chip">Table of Contents</span>
      <h1>{meta.title}</h1>
      <p>{meta.subtitle} · {meta.chapterCount} chapters · ~{meta.readingMinutes} min · {meta.pageCount} sections</p>
    </header>

    {groups.map((g) => (
      <section class="toc-group">
        <h2 class="toc-group-title">{g.name}</h2>
        <ol class="toc-list">
          {g.items.map((c) => (
            <li>
              <a href={`/read/${c.slug}/`}>
                <span class="t-num">{c.chapter ? String(c.chapter).padStart(2, "0") : "·"}</span>
                <span class="t-main">
                  <span class="t-title">{c.title}</span>
                  {c.excerpt && <span class="t-ex">{c.excerpt}</span>}
                </span>
                <span class="t-min">{c.readingMinutes} min</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </main>
</BaseLayout>

<style>
  .toc-page { max-width: 56rem; padding-top: 2.5rem; }
  .toc-hero { margin-bottom: 2.5rem; }
  .toc-hero h1 { font-size: clamp(1.9rem, 5vw, 2.8rem); margin: 0.9rem 0 0.5rem; }
  .toc-hero p { color: var(--muted); margin: 0; }
  .toc-group { margin-top: 2.4rem; }
  .toc-group-title {
    font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--faint); margin: 0 0 0.6rem;
    padding-bottom: 0.6rem; border-bottom: 1px solid var(--border);
  }
  .toc-list { list-style: none; margin: 0; padding: 0; }
  .toc-list a {
    display: grid; grid-template-columns: 2.5rem 1fr auto; gap: 1rem; align-items: baseline;
    padding: 0.9rem 0.6rem; border-radius: var(--radius-sm); color: var(--text);
  }
  .toc-list a:hover { background: var(--surface); text-decoration: none; }
  .t-num { font-family: var(--font-mono); color: var(--accent); }
  .t-title { font-weight: 600; color: var(--text-strong); }
  .t-ex {
    display: block; color: var(--muted); font-size: 0.9rem; margin-top: 0.2rem;
    display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .t-min { font-family: var(--font-mono); font-size: 0.76rem; color: var(--faint); white-space: nowrap; }
  @media (max-width: 560px) { .toc-list a { grid-template-columns: 1.8rem 1fr; } .t-min { display: none; } }
</style>
