---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <main id="main" class="container nf">
    <span class="chip">404</span>
    <h1>This page didn't survive the migration.</h1>
    <p>The page you're looking for isn't here. Let's get you back to safe ground.</p>
    <div class="nf-cta">
      <a class="btn btn-primary" href="/">Home</a>
      <a class="btn" href="/read/">Table of contents</a>
    </div>
  </main>
</BaseLayout>

<style>
  .nf { max-width: 40rem; padding: 6rem 1rem; text-align: center; }
  .nf h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); margin: 1rem 0 0.6rem; }
  .nf p { color: var(--muted); }
  .nf-cta { display: flex; gap: 0.8rem; justify-content: center; margin-top: 1.6rem; }
</style>
